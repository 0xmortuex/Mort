struct Pair {
    left: i64,
    right: i64,
}

fn main() -> int {
    let pair = Pair { left: 20, right: 22 };
    print(pair.left + pair.right);

    let tuple: (i64, bool) = (3, true);
    if tuple.1 {
        print(tuple.0);
    }

    let values: [i64; 3] = [7, 8, 9];
    let view: []i64 = slice(&values[0], len(values));
    print(view[2]);
    return 0;
}
