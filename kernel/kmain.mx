// MORT OS — an interrupt-driven shell written in Mort.
//
// boot.s installs a GDT/IDT and remaps the PICs (see idt.s), then calls
// mort_kmain, which draws a prompt, enables interrupts, and idles with `hlt`.
// Each keystroke raises IRQ1; the assembly stub calls on_key() below, which
// reads the scancode and drives the shell. Shell state lives in globals so it
// survives between interrupts.

// ----- shared shell state (globals) -----
let g_row: u32 = 2;
let g_col: u32 = 2;
let g_len: u32 = 0;
let g_shift: bool = false;
let g_buf: *u8 = "                                                                                ";   // 80-byte scratch (76 chars + NUL + slack), MAXLINE = 76
let g_ticks: u32 = 0;                                          // PIT ticks (100/s)
let g_numlen: u32 = 0;                                         // digits written by num_to_str
let g_numbuf: *u8 = "            ";                            // 12-byte number scratch
let g_mbinfo: u32 = 0;                                        // multiboot info pointer (from boot.s)
let g_ext: bool = false;                                      // saw the 0xE0 extended-scancode prefix
let g_hist_n: u32 = 0;                                         // total commands entered
let g_hist_nav: u32 = 0;                                       // 0 = live line, k = k-th most recent recalled
let g_disk_ok: bool = false;                                   // ata_init() found a drive
let g_fs_ok: bool = false;                                     // fs_init() verified the MortFS magic
let g_run_depth: u32 = 0;                                      // forbids nested `run` (FILEBUF reuse)
let g_pcol: u32 = 0;                                           // program-output cursor column (syscalls)
let g_gfx: bool = false;                                       // a linear framebuffer is available
let g_fb: u32 = 0;                                             // framebuffer base address
let g_fb_pitch: u32 = 0;                                       // bytes per scanline
let g_fb_w: u32 = 0;                                           // width in pixels
let g_fb_h: u32 = 0;                                           // height in pixels
let g_cur_r: u32 = 0;                                          // last drawn cursor cell (graphics)
let g_cur_c: u32 = 0;
let g_history: *u8 = "                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                ";                              // 8 slots x 80 bytes (command history ring)

