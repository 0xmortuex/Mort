    0, 28, 99, 67, 65, 193, 65, 65, 67, 98, 60, 0, 0, 0, 0, 0,
    0, 28, 99, 67, 65, 193, 65, 65, 67, 98, 60, 0, 0, 0, 0, 0,
    0, 0, 0, 34, 54, 28, 28, 54, 34, 0, 0, 0, 0, 0, 0, 0,
    2, 30, 102, 71, 73, 201, 201, 89, 83, 114, 60, 32, 32, 0, 0, 0,
